POLYMARKET_API_BASE="https://api.polymarket.com"

# Builder Program credentials
BUILDER_API_KEY="your-builder-api-key"
BUILDER_API_SECRET="your-builder-api-secret"

# Relayer / gasless execution
RELAYER_API_BASE="https://relayer.polymarket.com"
RELAYER_API_KEY="your-relayer-api-key"

# Wallet / signing (if applicable)
PRIVATE_KEY="0x..."
WALLET_ADDRESS="0x..."

# Database configuration
# Example: sqlite:///./polymarket_metrics.db
# Or: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL="sqlite:///./polymarket_metrics.db"

# Engine / risk defaults
MAX_DAILY_TX=3000
MAX_DAILY_NOTIONAL="100000"
MAX_MARKET_NOTIONAL="25000"
MAX_DAILY_DRAWDOWN="5000"

# Web app
WEB_HOST="0.0.0.0"
WEB_PORT="8000"

